#!/bin/sh
# prerm for dnfs-dkms
# Removes the DKMS module before package removal.

set -e

NAME=dnfs
VERSION=0.1.0

case "$1" in
    remove|deconfigure)
        if command -v dkms >/dev/null 2>&1; then
            echo "dnfs-dkms: removing DKMS module $NAME/$VERSION..."
            dkms remove -m $NAME -v $VERSION --all 2>/dev/null || true
        fi
        ;;
    upgrade|failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument: $1" >&2
        ;;
esac

exit 0
