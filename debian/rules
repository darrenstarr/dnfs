#!/usr/bin/make -f
# debian/rules for dnfs — uses dh sequencer

%:
	dh $@ --with dkms

# Override auto_install to handle DKMS source correctly
override_dh_dkms:
	dh_dkms -p dnfs-dkms

# Don't compress the DKMS source files
override_dh_compress:
	dh_compress -Xusr/src/dnfs-0.1.0/src/

# Strip binaries (skip Python scripts)
override_dh_strip:
	dh_strip --no-act

override_dh_auto_build:
	# No compile needed — Python/Ansible tools are interpreted
	true

override_dh_auto_clean:
	true
