From: enfs-dkms
Subject: [PATCH] include/linux/sunrpc/clnt.h: add cl_enfs + multipath_option, hide from genksyms

OpenEuler's enfs adds three fields to the RPC client API:
  - struct rpc_clnt::cl_enfs (bitfield) — set when enfs multipath is on
  - struct rpc_clnt::multipath_option — opaque per-client multipath state
  - struct rpc_create_args::multipath_option — passed in at clnt creation

KEY INSIGHT (this is what makes the build interoperate with stock
lockd/nfs_acl/nfsd modules): each new field is hidden from genksyms via
`#if !defined(__GENKSYMS__)`. genksyms generates the SAME symbol CRCs as
stock sunrpc.ko, so an unmodified stock lockd.ko (which has the stock
CRCs baked in) loads against our patched sunrpc.ko without
"disagrees about version of symbol" errors.

The bitfield case follows OpenEuler's exact pattern:
  #if defined(__GENKSYMS__) || !IS_ENABLED(CONFIG_SUNRPC_ENFS)
        cl_shutdown : 1;
  #else
        cl_shutdown : 1, cl_enfs : 1;
  #endif

Both bit-field clauses end the bit-field declaration with a semicolon
in their own block, so the rest of the struct layout is unchanged.

Trailing pointer fields (multipath_option) sit at the END of the struct
so when stock callers access older fields by offset everything still
works; only OUR sunrpc/nfs touches the new fields.

---
--- a/include/linux/sunrpc/clnt.h
+++ b/include/linux/sunrpc/clnt.h
@@ -64,7 +64,12 @@
 				cl_noretranstimeo: 1,/* No retransmit timeouts */
 				cl_autobind : 1,/* use getport() */
 				cl_chatty   : 1,/* be verbose */
+#if defined(__GENKSYMS__) || !IS_ENABLED(CONFIG_SUNRPC_ENFS)
 				cl_shutdown : 1,/* rpc immediate -EIO */
+#else
+				cl_shutdown : 1,/* rpc immediate -EIO */
+				cl_enfs     : 1,/* enfs multipath enabled */
+#endif
 				cl_netunreach_fatal : 1;
 						/* Treat ENETUNREACH errors as fatal */
 	struct xprtsec_parms	cl_xprtsec;	/* transport security policy */
@@ -96,6 +101,9 @@
 	unsigned int		cl_max_connect; /* max number of transports not to the same IP */
 	struct super_block *pipefs_sb;
 	atomic_t		cl_task_count;
+#if !defined(__GENKSYMS__) && IS_ENABLED(CONFIG_SUNRPC_ENFS)
+	void			*multipath_option;	/* hidden from genksyms so CRC matches stock */
+#endif
 };
 
 /*
@@ -155,6 +163,9 @@
 	struct xprtsec_parms	xprtsec;
 	unsigned long		connect_timeout;
 	unsigned long		reconnect_timeout;
+#if !defined(__GENKSYMS__) && IS_ENABLED(CONFIG_SUNRPC_ENFS)
+	void			*multipath_option;	/* hidden from genksyms so CRC matches stock */
+#endif
 };
 
 struct rpc_add_xprt_test {
