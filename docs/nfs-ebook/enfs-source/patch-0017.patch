From: enfs-dkms
Subject: [PATCH] net/sunrpc/xprtmultipath.c: export multipath helpers needed by enfs

enfs.ko (fs/nfs/enfs/) calls 5 helpers from this file across module
boundaries. Stock Ubuntu 7.0 keeps them all internal to sunrpc.ko:

  - xprt_switch_add_xprt_locked  (was static; need EXPORT)
  - rpc_xprt_switch_remove_xprt  (was non-static, no EXPORT)
  - xprt_switch_get              (was non-static, no EXPORT)
  - xprt_switch_put              (was non-static, no EXPORT)
  - xprt_iter_get_next           (was non-static, no EXPORT)

Drop `static` where applicable, add EXPORT_SYMBOL_GPL after each.
Forward declarations live in compat/enfs_compat.h.

---
--- a/net/sunrpc/xprtmultipath.c
+++ b/net/sunrpc/xprtmultipath.c
@@ -29,7 +29,7 @@
 static const struct rpc_xprt_iter_ops rpc_xprt_iter_listall;
 static const struct rpc_xprt_iter_ops rpc_xprt_iter_listoffline;
 
-static void xprt_switch_add_xprt_locked(struct rpc_xprt_switch *xps,
+void xprt_switch_add_xprt_locked(struct rpc_xprt_switch *xps,
 		struct rpc_xprt *xprt)
 {
 	if (unlikely(xprt_get(xprt) == NULL))
@@ -41,6 +41,7 @@
 	xps->xps_nxprts++;
 	xps->xps_nactive++;
 }
+EXPORT_SYMBOL_GPL(xprt_switch_add_xprt_locked);
 
 /**
  * rpc_xprt_switch_add_xprt - Add a new rpc_xprt to an rpc_xprt_switch
@@ -91,6 +92,7 @@
 	spin_unlock(&xps->xps_lock);
 	xprt_put(xprt);
 }
+EXPORT_SYMBOL_GPL(rpc_xprt_switch_remove_xprt);
 
 /**
  * rpc_xprt_switch_get_main_xprt - Get the 'main' xprt for an xprt switch.
@@ -208,6 +210,7 @@
 		return xps;
 	return NULL;
 }
+EXPORT_SYMBOL_GPL(xprt_switch_get);
 
 /**
  * xprt_switch_put - Release a reference to a rpc_xprt_switch
@@ -220,6 +223,7 @@
 	if (xps != NULL)
 		kref_put(&xps->xps_kref, xprt_switch_free);
 }
+EXPORT_SYMBOL_GPL(xprt_switch_put);
 
 /**
  * rpc_xprt_switch_set_roundrobin - Set a round-robin policy on rpc_xprt_switch
@@ -639,6 +643,7 @@
 	rcu_read_unlock();
 	return xprt;
 }
+EXPORT_SYMBOL_GPL(xprt_iter_get_next);
 
 /* Policy for always returning the first entry in the rpc_xprt_switch */
 static
