From: Darren Starr <darren@example.com>
Date: Tue, 5 May 2026 23:00:00 +0000
Subject: [PATCH 1/6] fs/nfs: add CONFIG_NFS_MULTIPATH for client multipath support

Add the DNFS configuration option to the NFS client Kconfig and
Makefile. When enabled, this option allows a single NFSv4.1 mount
to use multiple server addresses via the remoteaddrs= mount option.

The option depends on NFS_V4_1 because multipath relies on the
NFSv4.1 session model for ordered execution and duplicate detection
across transports.

Signed-off-by: Darren Starr <darren@example.com>
---
 fs/nfs/Kconfig  | 23 +++++++++++++++++++++++
 fs/nfs/Makefile |  1 +
 2 files changed, 24 insertions(+)

diff --git a/fs/nfs/Kconfig b/fs/nfs/Kconfig
index 99e1426..a4f7b23 100644
--- a/fs/nfs/Kconfig
+++ b/fs/nfs/Kconfig
@@ -185,6 +185,29 @@ config NFS_V4_1
 	  implementation.

 	  If unsure, say Y.
+
+config DNFS
+	bool "Distributed NFS (dnfs) client multipath support"
+	depends on NFS_V4_1
+	default n
+	help
+	  Enable client-side multipath for NFSv4.1 mounts. When selected,
+	  the mount option "remoteaddrs=" becomes available, allowing the
+	  user to specify a tilde-separated list of server IP addresses.
+
+	  The client creates a separate TCP connection to each address
+	  in the list and distributes NFS operations across all connections
+	  via the existing SunRPC transport switch. The NFSv4.1 session
+	  model provides ordered execution, duplicate detection, and
+	  failover semantics across all transports.
+
+	  No server changes are required -- all multipath logic runs on
+	  the client. The mount succeeds even if only one address is
+	  reachable.
+
+	  If unsure, say N.
+
 endif

 config ROOT_NFS
diff --git a/fs/nfs/Makefile b/fs/nfs/Makefile
index 18e4b77..c7c1e3a 100644
--- a/fs/nfs/Makefile
+++ b/fs/nfs/Makefile
@@ -9,6 +9,7 @@ obj-$(CONFIG_NFS_FS) += nfs.o
 CFLAGS_nfstrace.o += -I$(src)
 nfs-y 			:= client.o dir.o file.o getroot.o inode.o super.o \
 			   io.o direct.o pagelist.o read.o symlink.o unlink.o \
+			   nfs_multipath.o \
 			   write.o namespace.o mount_clnt.o nfstrace.o \
 			   export.o sysfs.o fs_context.o
 nfs-$(CONFIG_ROOT_NFS)	+= nfsroot.o
-- 
