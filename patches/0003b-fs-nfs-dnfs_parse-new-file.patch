From: Darren Starr <darren@example.com>
Date: Tue, 5 May 2026 23:00:00 +0000
Subject: [PATCH 3b/6] fs/nfs/dnfs_parse.c: new file for mount option parsing

Add the mount option parser implementation for the remoteaddrs=
option. This file is compiled into nfs.ko when CONFIG_DNFS=y.

The parser validates all input against length and count limits,
uses the kernel's rpc_pton() for address resolution, and properly
handles error cases (malformed addresses, memory allocation failures).

Signed-off-by: Darren Starr <darren@example.com>
---
 fs/nfs/dnfs_parse.c | 153 +++++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 153 insertions(+)

diff --git a/fs/nfs/dnfs_parse.c b/fs/nfs/dnfs_parse.c
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/fs/nfs/dnfs_parse.c
@@ -0,0 +1,153 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * fs/nfs/dnfs_parse.c -- Distributed NFS mount option parsing
+ *
+ * Implements the "remoteaddrs=" mount option parser for client-side
+ * NFSv4.1 multipath. Compiled into nfs.ko when CONFIG_DNFS is enabled.
+ *
+ * The remoteaddrs= option accepts a tilde-separated list of server
+ * addresses. Each address is validated using rpc_pton().
+ *
+ * Example:
+ *   mount -t nfs4 -o vers=4.1,remoteaddrs=10.0.0.1~10.0.0.2
+ */
+
+#include <linux/kernel.h>
+#include <linux/string.h>
+#include <linux/slab.h>
+#include <linux/errno.h>
+#include <linux/sunrpc/addr.h>
+#include <linux/nfs.h>
+
+#include "internal.h"
+
+#define DNFS_MAX_OPTION_STRLEN 4096
+
+void dnfs_free_address_list(struct dnfs_address_list *list)
+{
+	kfree(list);
+}
+
+int dnfs_parse_remoteaddrs(struct nfs_fs_context *ctx, const char *value)
+{
+	struct dnfs_address_list *list;
+	const char *p, *next;
+	unsigned int count = 0, max_count;
+	size_t val_len;
+	int ret;
+
+	if (!value || !*value)
+		return -EINVAL;
+
+	val_len = strlen(value);
+	if (val_len > DNFS_MAX_OPTION_STRLEN)
+		return -E2BIG;
+
+	/*
+	 * First pass: count tilde-separated tokens for allocation.
+	 */
+	p = value;
+	while (*p) {
+		while (*p == '~')
+			p++;
+		if (!*p)
+			break;
+		count++;
+		if (count >= CONFIG_DNFS_MAX_REMOTE_ADDRS)
+			break;
+		p = strchr(p, '~');
+		if (!p)
+			break;
+		p++;
+	}
+
+	if (count == 0)
+		return -EINVAL;
+
+	max_count = CONFIG_DNFS_MAX_REMOTE_ADDRS;
+	if (count > max_count)
+		return -E2BIG;
+
+	list = kzalloc(sizeof(*list) + (count * sizeof(list->addrs[0])),
+		       GFP_KERNEL);
+	if (!list)
+		return -ENOMEM;
+
+	list->count = 0;
+	list->max = count;
+
+	/*
+	 * Second pass: parse each address via rpc_pton().
+	 */
+	p = value;
+	while (*p && list->count < count) {
+		size_t token_len;
+
+		while (*p == '~')
+			p++;
+		if (!*p)
+			break;
+
+		next = strchr(p, '~');
+		if (next)
+			token_len = next - p;
+		else
+			token_len = strlen(p);
+
+		if (!rpc_pton(&init_net, p, token_len,
+			      (struct sockaddr *)&list->addrs[list->count],
+			      sizeof(list->addrs[list->count]))) {
+			pr_warn("NFS: dnfs: invalid address '%.*s'\n",
+				(int)token_len, p);
+			ret = -EINVAL;
+			goto out_free;
+		}
+
+		list->count++;
+
+		if (next)
+			p = next + 1;
+		else
+			break;
+	}
+
+	ctx->nfs_server.dnfs_remoteaddrs = list;
+	return 0;
+
+out_free:
+	kfree(list);
+	return ret;
+}
+-- 
+2.45.2
